{"openapi":"3.0.1","info":{"title":"Code Execution System API","description":"Secure backend system for executing user-submitted code.\n\n**Workflow:**\n1. `POST /code-sessions` — Create a live coding session\n2. `PATCH /code-sessions/{id}` — Autosave code as user types\n3. `POST /code-sessions/{id}/run` — Submit code for async execution\n4. `GET /executions/{id}` — Poll for result\n\n**Execution states:** `QUEUED → RUNNING → COMPLETED | FAILED | TIMEOUT`\n","contact":{"name":"Code Execution System"},"version":"1.0.0"},"servers":[{"url":"http://localhost:8080","description":"Local / Docker"}],"tags":[{"name":"Code Sessions","description":"Live coding session management APIs"},{"name":"Code Executions","description":"Code execution status and result retrieval APIs"}],"paths":{"/code-sessions":{"post":{"tags":["Code Sessions"],"summary":"Create a new live coding session","description":"Initializes a new session with a specified language and optional template code","operationId":"createSession","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/CreateSessionRequest"}}},"required":true},"responses":{"400":{"description":"Invalid request body","content":{"*/*":{"schema":{"$ref":"#/components/schemas/SessionResponse"}}}},"201":{"description":"Session created successfully","content":{"*/*":{"schema":{"$ref":"#/components/schemas/SessionResponse"}}}}}}},"/code-sessions/{sessionId}/run":{"post":{"tags":["Code Sessions"],"summary":"Submit code for execution","description":"Enqueues the current session code for asynchronous execution. Returns immediately with a job ID.","operationId":"runCode","parameters":[{"name":"sessionId","in":"path","description":"Session UUID","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"429":{"description":"Too many execution requests","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ExecutionResponse"}}}},"400":{"description":"No source code to execute","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ExecutionResponse"}}}},"202":{"description":"Execution job queued","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ExecutionResponse"}}}},"404":{"description":"Session not found","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ExecutionResponse"}}}}}}},"/code-sessions/{sessionId}":{"patch":{"tags":["Code Sessions"],"summary":"Autosave source code","description":"Saves the learner's current code. Called frequently during live editing.","operationId":"autosave","parameters":[{"name":"sessionId","in":"path","description":"Session UUID","required":true,"schema":{"type":"string","format":"uuid"}}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/AutosaveRequest"}}},"required":true},"responses":{"404":{"description":"Session not found or not active","content":{"*/*":{"schema":{"$ref":"#/components/schemas/SessionResponse"}}}},"429":{"description":"Rate limit exceeded","content":{"*/*":{"schema":{"$ref":"#/components/schemas/SessionResponse"}}}},"200":{"description":"Code saved successfully","content":{"*/*":{"schema":{"$ref":"#/components/schemas/SessionResponse"}}}}}}},"/executions/{executionId}":{"get":{"tags":["Code Executions"],"summary":"Get execution status and result","description":"Poll this endpoint to check execution progress. States: QUEUED → RUNNING → COMPLETED | FAILED | TIMEOUT","operationId":"getExecution","parameters":[{"name":"executionId","in":"path","description":"Execution UUID returned from /run","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"404":{"description":"Execution not found","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ExecutionResponse"}}}},"200":{"description":"Execution found","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ExecutionResponse"}}}}}}}},"components":{"schemas":{"CreateSessionRequest":{"required":["language"],"type":"object","properties":{"language":{"type":"string","description":"Programming language","example":"PYTHON","enum":["PYTHON","JAVASCRIPT"]},"templateCode":{"type":"string","description":"Initial template code","example":"# Write your code here\n"}},"description":"Request to create a new coding session"},"SessionResponse":{"type":"object","properties":{"sessionId":{"type":"string","description":"Session UUID","format":"uuid"},"status":{"type":"string","description":"Current status","example":"ACTIVE","enum":["ACTIVE","CLOSED"]},"language":{"type":"string","description":"Programming language","example":"PYTHON","enum":["PYTHON","JAVASCRIPT"]},"createdAt":{"type":"string","description":"Session creation timestamp","format":"date-time"}},"description":"Code session response"},"ExecutionResponse":{"type":"object","properties":{"executionId":{"type":"string","description":"Execution UUID","format":"uuid"},"sessionId":{"type":"string","description":"Associated session UUID","format":"uuid"},"status":{"type":"string","description":"Execution status","example":"COMPLETED","enum":["QUEUED","RUNNING","COMPLETED","FAILED","TIMEOUT"]},"stdout":{"type":"string","description":"Standard output","example":"Hello World\n"},"stderr":{"type":"string","description":"Standard error output"},"executionTimeMs":{"type":"integer","description":"Execution duration in milliseconds","format":"int64","example":120},"exitCode":{"type":"integer","description":"Exit code","format":"int32","example":0},"language":{"type":"string","description":"Programming language","enum":["PYTHON","JAVASCRIPT"]},"queuedAt":{"type":"string","description":"Timestamp when queued","format":"date-time"},"startedAt":{"type":"string","description":"Timestamp when execution started","format":"date-time"},"completedAt":{"type":"string","description":"Timestamp when execution completed","format":"date-time"}},"description":"Code execution response"},"AutosaveRequest":{"required":["language","sourceCode"],"type":"object","properties":{"language":{"type":"string","description":"Programming language","example":"PYTHON","enum":["PYTHON","JAVASCRIPT"]},"sourceCode":{"type":"string","description":"Current source code","example":"print('Hello World')"}},"description":"Request to autosave current source code"}}}}